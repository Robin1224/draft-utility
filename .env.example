# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"
# After pulling schema changes (e.g. new `room` tables), sync Neon: `npm run db:push`
# Non-interactive / CI: `npm run db:push:force` (auto-approves; use only when safe)

# Must match the URL you open in the browser (Vite default 5173; if port busy, Vite uses 5174+).
ORIGIN="http://localhost:5174"

# Optional public URL for documentation / future overrides. Lobby "Copy link" uses the HTTP request origin (see +page.server.js appOrigin).
# PUBLIC_APP_URL="https://your.domain"

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Discord OAuth (create app at https://discord.com/developers/applications)
# Register redirect URIs in Discord OAuth2 settings (must match ORIGIN host + port):
#   http://localhost:5173/api/auth/callback/discord
#   http://localhost:5174/api/auth/callback/discord  (when Vite picks next port)
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
